# ── Phoebe Configuration ────────────────────────────────────────────────────────
# Copy to .env and fill in your values. This file is gitignored — never commit secrets.

# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# API key from mume.ai (OpenRouter-compatible gateway)
MUME_API_KEY=

# Your Telegram user ID (receives startup notifications, can /restart)
OWNER_ID=

# ── Optional ────────────────────────────────────────────────────────────────────

# AI gateway endpoint (default: Mume AI)
# MUME_BASE_URL=https://mume.ai/api/v1

# OpenRouter API key (for fetching the model catalog)
# OPENROUTER_API_KEY=

# Default AI model (OpenRouter format: provider/model)
# AI_MODEL=google/gemini-3-flash-preview

# Max tool-call steps per message (default: 25)
# MAX_STEPS=25

# Comma-separated Telegram user IDs for access control (empty = everyone)
# ALLOWED_IDS=

# fal.ai API key — required for voice features (STT + TTS)
# FAL_KEY=

# ── Web Interface (Optional — requires Firebase) ───────────────────────────────

# Firebase service account key (JSON string)
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Firebase Auth UID of the owner
# FIREBASE_UID=

# Unique instance ID (e.g. phoebe-pi)
# PHOEBE_INSTANCE_ID=

# Firestore root document path (default: viper/v1)
# FIRESTORE_ROOT=viper/v1

# ── Paths (Docker defaults are fine — only change for custom setups) ────────────

# DATA_DIR=/app/data
# SKILLS_DIR=/app/skills
