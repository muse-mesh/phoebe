# ── Phoebe — AI Telegram Bot ───────────────────────────────────────────────────
# Copy this to .env on the deployment target and fill in your values.
# This file is gitignored — never commit secrets.

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Mume AI Gateway
MUME_API_KEY=
MUME_BASE_URL=https://mume.ai/api/v1

# Default AI model (OpenRouter format: provider/model)
AI_MODEL=google/gemini-3-flash-preview

# Max agentic steps per message (tool call loops)
MAX_STEPS=15

# Telegram user ID of the bot owner (receives startup notifications)
OWNER_ID=

# Comma-separated Telegram user IDs allowed to use the bot (empty = everyone)
ALLOWED_IDS=

# fal.ai API key (for speech-to-text and text-to-speech)
FAL_KEY=
