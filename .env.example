# ── Phoebe Configuration ────────────────────────────────────────────────────────
# Copy to .env and fill in your values. This file is gitignored — never commit secrets.

# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# API key for the gateway (Mume AI or OpenRouter)
GATEWAY_KEY=

# Your Telegram user ID (receives startup notifications, can /restart)
OWNER_ID=

# ── Optional ────────────────────────────────────────────────────────────────────

# OpenAI-compatible gateway URL (default: Mume AI, or use https://openrouter.ai/api/v1)
# GATEWAY_URL=https://mume.ai/api/v1

# OpenRouter API key — used to fetch the model catalog from openrouter.ai
# OR_API_KEY=

# Default AI model (provider/model format)
# AI_MODEL=google/gemini-3-flash-preview

# Max tool-call steps per message (default: 25)
# MAX_STEPS=25

# Comma-separated Telegram user IDs for access control (empty = everyone)
# ALLOWED_IDS=

# fal.ai API key — required for voice features (STT + TTS)
# FAL_KEY=

# ── Ollama (Optional — local model inference) ──────────────────────────────────

# Set this to enable local Ollama models alongside cloud models.
# Ollama models appear in the catalog prefixed with "ollama/" (e.g. ollama/llama3.2)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── LM Studio (Optional — local model inference) ───────────────────────────────

# Set this to enable local LM Studio models alongside cloud models.
# LM Studio models appear in the catalog prefixed with "lmstudio/"
# LMSTUDIO_BASE_URL=http://host.docker.internal:1234

# ── Paths (Docker defaults are fine — only change for custom setups) ────────────

# DATA_DIR=/app/data
# SKILLS_DIR=/app/skills

# ── Healthcheck ─────────────────────────────────────────────────────────────────

# HTTP port for the /health endpoint (default: 8080)
# HEALTH_PORT=8080

# ── Logging ─────────────────────────────────────────────────────────────────────

# Set to "true" for JSON log output (for log aggregators like Loki, Datadog)
# JSON_LOGGING=false

# ── Rate Limiting ───────────────────────────────────────────────────────────────

# Max messages per user per window (0 = disabled)
# RATE_LIMIT_MESSAGES=0
# Window duration in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW=60000

# ── Custom System Prompt ────────────────────────────────────────────────────────

# Override the default system prompt with a custom one (inline or file)
# SYSTEM_PROMPT="You are a helpful assistant..."
# SYSTEM_PROMPT_FILE=/app/data/system-prompt.md
